<Base title="LLM Observability with OpenTelemetry: A Vendor-Neutral Field Guide" description="Instrument LLM calls, RAG pipelines, and agents with vendor-neutral OpenTelemetry spans, events, privacy controls, dashboards, and SLOs." pageKind="content" contentType="guide" topic="monitoring">
