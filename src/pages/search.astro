---
import Base from '../layouts/Base.astro';
import { getAllContentWithPaths } from '../lib/content';

const allContent = getAllContentWithPaths();

const prefixLabels: Record<string, string> = {
  resources: 'Resource',
  checklists: 'Checklist',
  comparisons: 'Comparison',
  guides: 'Guide',
  tools: 'Tool',
  directories: 'Directory',
};

const searchIndex = allContent.map(({ content, urlPrefix, slug }) => ({
  title: content.seo.title,
  description: content.seo.description,
  url: `/${urlPrefix}/${slug}/`,
  type: prefixLabels[urlPrefix] ?? urlPrefix,
}));
---

<Base
  title="Search"
  description="Search across all AI Stripes resources, guides, checklists, comparisons, tools, and directories."
  noindex={true}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Search</h1>

    <input
      type="search"
      id="search-input"
      placeholder="Search resources, guides, checklists..."
      class="w-full px-4 py-3 border border-gray-300 rounded-xl text-base focus:outline-none focus:ring-2 focus:ring-blue-500 mb-6"
      autofocus
    />

    <div id="search-results" class="space-y-3"></div>
    <p id="search-empty" class="text-gray-400 text-center py-10 hidden">No results found.</p>
    <p id="search-hint" class="text-gray-400 text-center py-10">Start typing to search…</p>
  </div>
</Base>

<script is:inline define:vars={{ searchIndex }}>
  const input = document.getElementById('search-input');
  const resultsEl = document.getElementById('search-results');
  const emptyEl = document.getElementById('search-empty');
  const hintEl = document.getElementById('search-hint');

  function render(results) {
    resultsEl.innerHTML = '';
    if (results === null) {
      hintEl.classList.remove('hidden');
      emptyEl.classList.add('hidden');
      return;
    }
    hintEl.classList.add('hidden');
    if (results.length === 0) {
      emptyEl.classList.remove('hidden');
      return;
    }
    emptyEl.classList.add('hidden');
    results.forEach(({ title, description, url, type }) => {
      const a = document.createElement('a');
      a.href = url;
      a.className = 'block border border-gray-200 rounded-xl p-4 hover:border-blue-300 hover:shadow-sm transition-all';
      a.innerHTML = `
        <div class="flex items-center gap-2 mb-1">
          <span class="text-xs font-medium text-blue-600 bg-blue-50 px-2 py-0.5 rounded">${type}</span>
        </div>
        <h2 class="font-semibold text-gray-900 mb-1">${title}</h2>
        <p class="text-sm text-gray-500 line-clamp-2">${description}</p>
      `;
      resultsEl.appendChild(a);
    });
  }

  input.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();
    if (!q) {
      render(null);
      return;
    }
    const results = searchIndex.filter(
      ({ title, description }) =>
        title.toLowerCase().includes(q) || description.toLowerCase().includes(q)
    );
    render(results);
  });
</script>
