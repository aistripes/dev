---
import Base from '../../layouts/Base.astro';
import SectionIcon from '../../components/SectionIcon.astro';
import { getAllContentWithPaths } from '../../lib/content';

export function getStaticPaths() {
  return [
    { params: { prefix: 'resources' } },
    { params: { prefix: 'checklists' } },
    { params: { prefix: 'comparisons' } },
    { params: { prefix: 'guides' } },
    { params: { prefix: 'tools' } },
    { params: { prefix: 'directories' } },
  ];
}

type SectionPrefix = 'resources' | 'checklists' | 'comparisons' | 'guides' | 'tools' | 'directories';

const { prefix } = Astro.params as { prefix: SectionPrefix };

const labels: Record<string, { title: string; description: string }> = {
  resources: {
    title: 'Resources',
    description: 'Curated idea lists, tip collections, and structured resources for AI-powered web development.',
  },
  checklists: {
    title: 'Checklists',
    description: 'Interactive, completable checklists covering deployment, compliance, security, and more.',
  },
  comparisons: {
    title: 'Comparisons',
    description: 'Structured head-to-head comparisons with detailed criteria and verdicts.',
  },
  guides: {
    title: 'Guides',
    description: 'Step-by-step implementation guides with code examples and common pitfalls.',
  },
  tools: {
    title: 'Tools',
    description: 'Interactive utilities that run entirely in your browser. No sign-up required.',
  },
  directories: {
    title: 'Directories',
    description: 'Curated, filterable listings of tools, services, and resources.',
  },
};

const meta = labels[prefix] ?? { title: prefix, description: '' };

const items = getAllContentWithPaths().filter((c) => c.urlPrefix === prefix);
---

<Base title={meta.title} description={meta.description} pageKind="collection">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-blue-600">
          <SectionIcon section={prefix} class="w-10 h-10" />
        </span>
        <h1 class="text-3xl font-bold text-gray-900">{meta.title}</h1>
      </div>
      <p class="text-gray-600">{meta.description}</p>
    </header>

    {prefix === 'guides' && (
      <div class="mb-8 grid gap-4 md:grid-cols-2">
        <a href="/guides/self-hosted-llm/" class="block rounded-2xl border-2 border-blue-200 bg-blue-50 p-6 hover:border-blue-400 transition-colors">
          <p class="text-xs font-bold uppercase tracking-wider text-blue-700 mb-2">Flagship field guide + calculator</p>
          <h2 class="text-xl font-bold text-gray-900 mb-2">How to self-host an LLM</h2>
          <p class="text-gray-600">An honest serving-stack matrix, memory sizing method, security plan, production metrics, and breakeven worksheet.</p>
        </a>
        <a href="/guides/llm-observability/" class="block rounded-2xl border-2 border-blue-200 bg-blue-50 p-6 hover:border-blue-400 transition-colors">
          <p class="text-xs font-bold uppercase tracking-wider text-blue-700 mb-2">Flagship field guide + download</p>
          <h2 class="text-xl font-bold text-gray-900 mb-2">LLM observability with OpenTelemetry</h2>
          <p class="text-gray-600">A vendor-neutral span and event model for model calls, RAG, agents, privacy controls, dashboards, and SLO design.</p>
        </a>
      </div>
    )}

    {prefix === 'tools' && (
      <a href="/tools/self-hosted-llm-cost-calculator/" class="block mb-8 rounded-2xl border-2 border-blue-200 bg-blue-50 p-6 hover:border-blue-400 transition-colors">
        <p class="text-xs font-bold uppercase tracking-wider text-blue-700 mb-2">Featured free calculator</p>
        <h2 class="text-xl font-bold text-gray-900 mb-2">Self-hosted LLM cost calculator</h2>
        <p class="text-gray-600">Compare separate input, output, and cached-token API rates with fully loaded infrastructure and operations cost.</p>
      </a>
    )}

    {items.length === 0 ? (
      <p class="text-gray-500 text-center py-20">No content yet. Check back soon.</p>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {items.map(({ content, slug }) => (
          <a
            href={`/${prefix}/${slug}/`}
            class="block border border-gray-200 rounded-xl p-5 hover:border-blue-300 hover:shadow-sm transition-all"
          >
            <h2 class="font-semibold text-gray-900 mb-2 line-clamp-2">{content.seo.title}</h2>
            <p class="text-sm text-gray-500 line-clamp-3">{content.seo.description}</p>
          </a>
        ))}
      </div>
    )}
  </div>
</Base>
