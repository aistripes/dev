---
import SEOHead from '../components/SEOHead.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  keywords?: string[];
  ogTitle?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <SEOHead {...props} />
  <body class="min-h-screen flex flex-col">
    <!-- Eurolytics noscript fallback -->
    <noscript><img src="https://pixel.eurolytics.io/noscript?id=e3e32f8a-efdd-41d8-b13e-9682c03bcbc6" style="display:none" width="1" height="1" alt="" /></noscript>
    <Navigation />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
