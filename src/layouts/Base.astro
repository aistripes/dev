---
import SEOHead from '../components/SEOHead.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  keywords?: string[];
  ogTitle?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <SEOHead {...props} />
  <body class="min-h-screen flex flex-col">
    <Navigation />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <!-- Eurolytics: AI & Bot Crawler Detection -->
    <noscript><img src="https://events.eurolytics.app/p.gif?s=e3e32f8a-efdd-41d8-b13e-9682c03bcbc6" alt="" width="1" height="1" style="position:absolute;left:-9999px"></noscript>
    <a href="https://events.eurolytics.app/hp?s=e3e32f8a-efdd-41d8-b13e-9682c03bcbc6" rel="nofollow" style="position:absolute;left:-9999px" aria-hidden="true" tabindex="-1">.</a>
  </body>
</html>
