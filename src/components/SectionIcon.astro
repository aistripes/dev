---
export interface Props {
  section: 'resources' | 'checklists' | 'comparisons' | 'guides' | 'tools' | 'directories';
  class?: string;
}

const { section, class: className = 'w-8 h-8' } = Astro.props;
---

{section === 'resources' && (
  <!-- Resources: layered pages / stack of documents -->
  <svg class={className} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <!-- bottom layer -->
    <rect x="5" y="12" width="20" height="14" rx="2.5" fill="currentColor" opacity="0.15"/>
    <!-- middle layer -->
    <rect x="5" y="8" width="20" height="14" rx="2.5" fill="currentColor" opacity="0.35"/>
    <!-- top layer -->
    <rect x="5" y="5" width="20" height="14" rx="2.5" fill="currentColor" opacity="1"/>
    <!-- lines on top doc -->
    <line x1="9" y1="10" x2="23" y2="10" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="9" y1="13" x2="23" y2="13" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="9" y1="16" x2="17" y2="16" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
)}

{section === 'checklists' && (
  <!-- Checklists: clipboard with checkmarks -->
  <svg class={className} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <!-- clipboard body -->
    <rect x="6" y="7" width="20" height="22" rx="2.5" fill="currentColor" opacity="0.15"/>
    <rect x="6" y="7" width="20" height="22" rx="2.5" stroke="currentColor" stroke-width="1.75"/>
    <!-- clipboard tab -->
    <rect x="11" y="4" width="10" height="5" rx="2" fill="currentColor"/>
    <!-- check rows -->
    <!-- row 1 -->
    <rect x="10" y="14" width="4" height="4" rx="1" fill="currentColor" opacity="0.25"/>
    <polyline points="11,16 12.2,17.2 14,15" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <line x1="17" y1="16" x2="22" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <!-- row 2 -->
    <rect x="10" y="20" width="4" height="4" rx="1" fill="currentColor" opacity="0.25"/>
    <polyline points="11,22 12.2,23.2 14,21" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <line x1="17" y1="22" x2="22" y2="22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
)}

{section === 'comparisons' && (
  <!-- Comparisons: balance / versus split columns -->
  <svg class={className} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <!-- left column -->
    <rect x="4" y="8" width="10" height="18" rx="2.5" fill="currentColor" opacity="0.2"/>
    <rect x="4" y="8" width="10" height="18" rx="2.5" stroke="currentColor" stroke-width="1.75"/>
    <!-- left bars -->
    <rect x="6.5" y="11" width="5" height="2" rx="1" fill="currentColor" opacity="0.7"/>
    <rect x="6.5" y="15" width="5" height="2" rx="1" fill="currentColor" opacity="0.7"/>
    <rect x="6.5" y="19" width="3" height="2" rx="1" fill="currentColor" opacity="0.7"/>
    <!-- right column -->
    <rect x="18" y="8" width="10" height="18" rx="2.5" fill="currentColor" opacity="0.2"/>
    <rect x="18" y="8" width="10" height="18" rx="2.5" stroke="currentColor" stroke-width="1.75"/>
    <!-- right bars -->
    <rect x="20.5" y="11" width="5" height="2" rx="1" fill="currentColor" opacity="0.7"/>
    <rect x="20.5" y="15" width="3" height="2" rx="1" fill="currentColor" opacity="0.7"/>
    <rect x="20.5" y="19" width="5" height="2" rx="1" fill="currentColor" opacity="0.7"/>
    <!-- vs divider -->
    <line x1="16" y1="9" x2="16" y2="26" stroke="currentColor" stroke-width="1.5" stroke-dasharray="2 2" opacity="0.5"/>
  </svg>
)}

{section === 'guides' && (
  <!-- Guides: compass rose -->
  <svg class={className} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <!-- outer circle -->
    <circle cx="16" cy="16" r="12" stroke="currentColor" stroke-width="1.75" fill="currentColor" opacity="0.08"/>
    <!-- tick marks -->
    <line x1="16" y1="5" x2="16" y2="7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="16" y1="24.5" x2="16" y2="27" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="5" y1="16" x2="7.5" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="24.5" y1="16" x2="27" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <!-- north arrow (filled) -->
    <polygon points="16,8 13.5,18 16,16.5 18.5,18" fill="currentColor"/>
    <!-- south arrow (outline) -->
    <polygon points="16,24 18.5,14 16,15.5 13.5,14" fill="currentColor" opacity="0.3"/>
    <!-- center dot -->
    <circle cx="16" cy="16" r="2" fill="currentColor"/>
  </svg>
)}

{section === 'tools' && (
  <!-- Tools: wrench + sparkle -->
  <svg class={className} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <!-- wrench body -->
    <path
      d="M19.5 5.5 A6 6 0 0 0 8.5 13.5 L5 27 A1 1 0 0 0 6.5 28 L8 27 L9 24 L24 9 Z"
      fill="currentColor" opacity="0.2"/>
    <!-- wrench outline -->
    <path
      d="M20 6 C23.5 6 26 8.5 26 12 C26 14.5 24.5 16.5 22.5 17.5 L9.5 28.5 C8.5 29.5 7 29.5 6 28.5 C5 27.5 5 26 6 25 L17 12 C16 10 16 8 17 6.5 C18 5.5 19 5 20 6Z"
      stroke="currentColor" stroke-width="1.75" stroke-linejoin="round" fill="none"/>
    <!-- sparkle at top-right -->
    <line x1="25" y1="5" x2="25" y2="8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.8"/>
    <line x1="23.5" y1="6.5" x2="26.5" y2="6.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.8"/>
    <line x1="23.9" y1="5.4" x2="26.1" y2="7.6" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" opacity="0.5"/>
    <line x1="26.1" y1="5.4" x2="23.9" y2="7.6" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" opacity="0.5"/>
  </svg>
)}

{section === 'directories' && (
  <!-- Directories: grid of cards with magnifier -->
  <svg class={className} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <!-- grid cards -->
    <rect x="4" y="4" width="10" height="10" rx="2" fill="currentColor" opacity="0.3"/>
    <rect x="4" y="17" width="10" height="10" rx="2" fill="currentColor" opacity="0.2"/>
    <rect x="17" y="4" width="10" height="10" rx="2" fill="currentColor" opacity="0.2"/>
    <!-- magnifier over bottom-right cell -->
    <rect x="17" y="17" width="10" height="10" rx="2" fill="currentColor" opacity="0.1"/>
    <circle cx="22" cy="22.5" r="3.5" stroke="currentColor" stroke-width="1.75" fill="none"/>
    <line x1="24.5" y1="25" x2="27" y2="27.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
    <!-- dot details on cards -->
    <circle cx="9" cy="9" r="1.5" fill="currentColor" opacity="0.7"/>
    <circle cx="9" cy="22" r="1.5" fill="currentColor" opacity="0.5"/>
    <circle cx="22" cy="9" r="1.5" fill="currentColor" opacity="0.5"/>
  </svg>
)}
