        "name": "selector",
        "label": "DOM Selector",
        "type": "text",
        "placeholder": "e.g. #item-123",
        "required": true
      }
    ],
    "examples": [
      {
        "label": "Update item partial",
        "input": {
          "component_name": "item",
          "action": "update",
