{
  "meta": {
    "content_type": "tool-page",
    "niche": "structured-output",
    "generated_at": "2026-03-12T00:00:00.000Z",
    "schema_version": "1.0"
  },
  "seo": {
    "title": "JSON Schema Sanitizer for Structured Output",
    "description": "Clean and normalize JSON Schema before sending it to LLM structured-output APIs like Gemini.",
    "keywords": [
      "structured-output",
      "json schema",
      "gemini",
      "zod",
      "schema sanitizer"
    ],
    "slug": "structured-output-json-schema-sanitizer"
  },
  "content": {
    "headline": "Sanitize JSON Schema for LLM APIs",
    "description": "Prepare JSON Schema for stricter structured-output APIs by removing unsupported fields and normalizing common incompatibilities.",
    "tool_type": "formatter",
    "delivery": {
      "mode": "run",
      "runner": "client",
      "output": {
        "type": "json",
        "label": "Sanitized schema JSON"
      }
    },
    "inputs": [
      {
        "name": "schema_json",
        "label": "Input JSON Schema",
        "type": "textarea",
        "placeholder": "{ \"type\": \"object\", \"properties\": { ... } }",
        "required": true
      },
      {
        "name": "remove_additional_properties",
        "label": "Remove additionalProperties keys",
        "type": "checkbox",
        "required": false
      },
      {
        "name": "convert_const_to_enum",
        "label": "Convert const to single-value enum",
        "type": "checkbox",
        "required": false
      },
      {
        "name": "strip_meta_keywords",
        "label": "Strip metadata keywords ($schema, $defs, $id, default, examples)",
        "type": "checkbox",
        "required": false
      }
    ],
    "examples": [
      {
        "label": "Remove unsupported metadata and const",
        "input": {
          "schema_json": "{\"$schema\":\"http://json-schema.org/draft-07/schema#\",\"type\":\"object\",\"properties\":{\"kind\":{\"const\":\"guide\"}},\"additionalProperties\":false}",
          "remove_additional_properties": true,
          "convert_const_to_enum": true,
          "strip_meta_keywords": true
        },
        "expected_output": "{\"type\":\"object\",\"properties\":{\"kind\":{\"enum\":[\"guide\"]}}}"
      },
      {
        "label": "Only normalize const to enum",
        "input": {
          "schema_json": "{\"type\":\"object\",\"properties\":{\"status\":{\"const\":\"ok\"}}}",
          "remove_additional_properties": false,
          "convert_const_to_enum": true,
          "strip_meta_keywords": false
        },
        "expected_output": "{\"type\":\"object\",\"properties\":{\"status\":{\"enum\":[\"ok\"]}}}"
      }
    ],
    "how_it_works": "The tool parses your schema, walks nested objects, and applies deterministic transforms selected by toggles. Use it before calling structured-output APIs to reduce schema rejection and improve response consistency.",
    "related_tools": [
      "rag-context-window-calculator",
      "nextjs-metadata-validator"
    ]
  }
}
