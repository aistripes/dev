        "label": "Check SEO Best Practices",
        "type": "checkbox",
        "required": false
      }
    ],
    "examples": [
      {
        "label": "Basic Blog Model Validation",
        "input": {
          "modelStructure": "{ \"type\": \"document\", \"name\": \"blogPost\", \"fields\": [{ \"name\": \"title\", \"type\": \"string\" }, { \"name\": \"body\", \"type\": \"text\" }] }",
