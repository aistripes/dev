        "input": {
          "modelStructure": "{ \"type\": \"document\", \"name\": \"product\", \"fields\": [{ \"name\": \"name\", \"type\": \"string\" }, { \"name\": \"variants\", \"type\": \"array\", \"items\": { \"type\": \"object\", \"fields\": [{ \"name\": \"sku\", \"type\": \"string\" }] } }] }",
          "cmsPlatform": "Sanity",
          "includeSEO": false
